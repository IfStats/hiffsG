VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Paystack — this is the PUBLIC key only (starts with pk_). Safe to expose
# in the browser bundle. The SECRET key (sk_...) never goes here — it's set
# as a Supabase Edge Function secret instead (see README).
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
